{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "principalId": {
      "type": "string",
      "metadata": {
        "description": "The object ID (PrincipalId) of the managed identity."
      }
    },
    "subscriptionId": {
      "type": "string",
      "defaultValue": "[subscription().subscriptionId]"
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the deployment script resource."
      }
    }
  },
  "variables": {
    "roleAssignments": [
      {
        "role": "Contributor",
        "roleDefinitionId": "b24988ac-6180-42a0-ab88-20f7382dd24c"
      },
      {
        "role": "NetworkContributor",
        "roleDefinitionId": "4d97b98b-1d4f-4787-a291-c67834d212e7"
      },
      {
        "role": "ManagedIdentityOperator",
        "roleDefinitionId": "f1a07417-d97a-45cb-824c-7a7467783830"
      },
      {
        "role": "StorageBlobDataOwner",
        "roleDefinitionId": "ba92f5b4-2d11-453d-a403-e96b0029c9fe"
      }
    ]
  },
  "resources": [
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('principalId'), 'Contributor', parameters('resourceGroupName'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b24988ac-6180-42a0-ab88-20f7382dd24c')]",
        "description": "Contributor",
        "principalId": "[parameters('principalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('principalId'), 'NetworkContributor', parameters('resourceGroupName'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4d97b98b-1d4f-4787-a291-c67834d212e7')]",
        "description": "Network Contributor",
        "principalId": "[parameters('principalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('principalId'), 'ManagedIdentityOperator', parameters('resourceGroupName'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'f1a07417-d97a-45cb-824c-7a7467783830')]",
        "description": "Managed Identity Operator",
        "principalId": "[parameters('principalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('principalId'), 'StorageBlobDataOwner', parameters('resourceGroupName'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ba92f5b4-2d11-453d-a403-e96b0029c9fe')]",
        "description": "Storage Blob Data Owner",
        "principalId": "[parameters('principalId')]",
        "principalType": "ServicePrincipal"
      }
    }
  ]
}